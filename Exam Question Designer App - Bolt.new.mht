button { cursor: pointer; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; background: none; color: inherit; }

a { color: var(--primary); text-decoration: none; }

.topbar { position: sticky; top: 0px; z-index: 100; display: flex; align-items: center; gap: 8px; background: var(--primary); color: rgb(255, 255, 255); padding: 8px 12px; box-shadow: var(--shadow-lg); flex-wrap: wrap; }

.topbar .logo { font-size: 18px; font-weight: 700; white-space: nowrap; margin-left: 8px; }

.topbar nav { display: flex; gap: 4px; flex-wrap: wrap; flex: 1 1 0%; }

.topbar nav button { color: rgb(255, 255, 255); padding: 8px 14px; border-radius: 8px; min-height: var(--min-touch); display: flex; align-items: center; gap: 6px; font-size: 14px; transition: background 0.2s; }

.topbar nav button:hover { background: rgba(255, 255, 255, 0.15); }

.topbar nav button.active { background: rgba(255, 255, 255, 0.25); font-weight: 600; }

.topbar .spacer { flex: 1 1 0%; }

.topbar .icon-btn { min-width: var(--min-touch); min-height: var(--min-touch); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20px; background: rgba(255, 255, 255, 0.12); transition: background 0.2s; }

.topbar .icon-btn:hover { background: rgba(255, 255, 255, 0.25); }

main { max-width: 1100px; margin: 0px auto; padding: 16px; }

.panel { display: none; }

.panel.active { display: block; animation: 0.3s ease 0s 1 normal none running fadeIn; }

@keyframes fadeIn { 
  0% { opacity: 0; transform: translateY(8px); }
  100% { opacity: 1; transform: none; }
}

.card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px; margin-bottom: 16px; box-shadow: var(--shadow); }

.card h2 { font-size: 17px; margin-bottom: 12px; color: var(--primary); display: flex; align-items: center; gap: 8px; }

.card h3 { font-size: 15px; margin: 12px 0px 8px; color: var(--primary-dark); }

[data-theme="dark"] .card h3 { color: var(--primary-light); }

.field { margin-bottom: 10px; }

.field label { display: block; font-size: 13px; margin-bottom: 4px; color: var(--text-muted); }

.field input, .field select, .field textarea { width: 100%; padding: 8px 10px; border: 1px solid var(--border); border-radius: 8px; background: var(--surface); color: var(--text); min-height: var(--min-touch); }

.field textarea { min-height: 80px; resize: vertical; }

.field input:focus, .field select:focus, .field textarea:focus { outline: none; border-color: var(--primary); box-shadow: rgba(13, 59, 102, 0.12) 0px 0px 0px 3px; }

.row { display: flex; gap: 10px; flex-wrap: wrap; }

.row > * { flex: 1 1 0%; min-width: 140px; }

.row.fixed > * { flex: 0 0 auto; }

.btn { display: inline-flex; align-items: center; justify-content: center; gap: 6px; padding: 8px 16px; border-radius: 8px; min-height: var(--min-touch); font-size: 14px; background: var(--primary); color: rgb(255, 255, 255); transition: filter 0.2s, background 0.2s; }

.btn:hover { filter: brightness(1.1); }

.btn:active { transform: scale(0.97); }

.btn.secondary { background: var(--surface-2); color: var(--text); border: 1px solid var(--border); }

.btn.accent { background: var(--accent); }

.btn.warn { background: var(--warn); color: rgb(255, 255, 255); }

.btn.err { background: var(--err); color: rgb(255, 255, 255); }

.btn.sm { padding: 4px 10px; min-height: 32px; font-size: 12px; }

.btn.full { width: 100%; }

.btn-row { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 10px; }

.qtable { width: 100%; border-collapse: collapse; background: var(--surface); border-radius: var(--radius); overflow: hidden; }

.qtable th, .qtable td { padding: 8px 10px; border: 1px solid var(--border); text-align: right; vertical-align: top; }

.qtable th { background: var(--primary); color: rgb(255, 255, 255); font-weight: 600; font-size: 13px; }

.qtable tr:nth-child(2n) td { background: var(--surface-2); }

.qtable .qops { display: flex; gap: 4px; flex-wrap: wrap; }

.qtable .qops button { min-width: 32px; min-height: 32px; border-radius: 6px; font-size: 16px; background: var(--surface-2); border: 1px solid var(--border); }

.qtable .qops button:hover { background: var(--primary); color: rgb(255, 255, 255); }

.qtable .qops .del:hover { background: var(--err); }

.qtable .sub-q { padding: 2px 0px; }

.qtable .sub-q .sub-label { display: inline-block; min-width: 24px; color: var(--primary); font-weight: 700; margin-left: 6px; }

.section-tag { display: inline-block; background: var(--accent); color: rgb(255, 255, 255); padding: 2px 10px; border-radius: 20px; font-size: 12px; margin-bottom: 6px; }

.header-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }

@media (max-width: 640px) {
  .header-grid { grid-template-columns: 1fr; }
}

.header-field { display: flex; flex-direction: column; gap: 4px; background: var(--surface-2); border: 1px solid var(--border); border-radius: 8px; padding: 6px 8px; }

.header-field .hf-top { display: flex; align-items: center; justify-content: space-between; gap: 4px; }

.header-field .hf-top input { flex: 1 1 0%; border: 1px solid var(--border); border-radius: 6px; padding: 6px 8px; background: var(--surface); color: var(--text); min-height: 36px; }

.header-field .hf-val-row { display: flex; gap: 4px; align-items: center; }

.header-field .hf-val-row input { flex: 1 1 0%; border: 1px solid var(--border); border-radius: 6px; padding: 6px 8px; background: var(--surface); color: var(--text); min-height: 36px; }

.header-field .remove-x { min-width: 32px; min-height: 32px; border-radius: 50%; background: var(--err); color: rgb(255, 255, 255); font-size: 16px; display: flex; align-items: center; justify-content: center; flex: 0 0 auto; }

.header-field .remove-x:hover { filter: brightness(1.1); }

.header-img-box { border: 2px dashed var(--border); border-radius: 8px; padding: 10px; margin-top: 10px; text-align: center; }

.header-img-box.has-img { border-style: solid; border-color: var(--accent); }

.header-img-box img { max-width: 100%; max-height: 120px; border-radius: 6px; }

.mm-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px; }

.mm-grid .field { margin: 0px; }

.ruler-display { background: var(--surface-2); border: 1px dashed var(--primary); border-radius: 8px; padding: 12px; margin-bottom: 14px; display: flex; flex-direction: column; gap: 6px; font-size: 13px; }

.ruler-display .ruler-item { display: flex; align-items: center; gap: 8px; }

.ruler-display .ruler-bar { height: 6px; border-radius: 3px; flex: 1 1 0%; min-width: 60px; }

.ruler-display .ruler-val { font-weight: 700; color: var(--primary); min-width: 70px; text-align: left; }

.bank-item { background: var(--surface-2); border: 1px solid var(--border); border-radius: 8px; padding: 10px; margin-bottom: 8px; }

.bank-item .bi-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px; }

.bank-item .bi-type { font-size: 12px; background: var(--primary); color: rgb(255, 255, 255); padding: 2px 8px; border-radius: 12px; }

.bank-item .bi-text { font-size: 13px; color: var(--text); }

.bank-item .bi-date { font-size: 11px; color: var(--text-muted); }

#printArea { display: none; }

#printArea.printing { display: block; }

.guide-item { margin-bottom: 12px; padding: 10px; background: var(--surface-2); border-radius: 8px; border-right: 4px solid var(--primary); }

.guide-item h4 { color: var(--primary); margin-bottom: 4px; }

@media (max-width: 640px) {
  .topbar .logo { font-size: 15px; width: 100%; text-align: center; }
  .topbar nav { justify-content: center; }
  .topbar nav button { padding: 6px 10px; font-size: 13px; }
  .qtable { font-size: 12px; }
  .qtable th, .qtable td { padding: 5px 6px; }
  .row > * { min-width: 100%; flex: 1 1 100%; }
  main { padding: 10px; }
  .card { padding: 12px; }
}

#toast { position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%); z-index: 300; background: var(--primary); color: rgb(255, 255, 255); padding: 10px 20px; border-radius: 24px; font-size: 14px; box-shadow: var(--shadow-lg); opacity: 0; pointer-events: none; transition: opacity 0.3s, transform 0.3s; }

#toast.show { opacity: 1; transform: translateX(-50%) translateY(0px); }

.img-preview { max-width: 120px; max-height: 120px; border-radius: 6px; border: 1px solid var(--border); margin-top: 6px; display: block; }

.img-thumb { max-width: 60px; max-height: 60px; border-radius: 4px; vertical-align: middle; }

.sub-q-row { display: flex; gap: 6px; align-items: flex-start; margin-bottom: 6px; padding: 6px; background: var(--surface-2); border-radius: 6px; }

.sub-q-row .sub-letter { font-weight: 700; color: var(--primary); min-width: 24px; padding-top: 6px; }

.sub-q-row input { flex: 1 1 0%; border: 1px solid var(--border); border-radius: 6px; padding: 6px; background: var(--surface); color: var(--text); }

.match-row { display: flex; gap: 6px; align-items: center; margin-bottom: 6px; }

.match-row input { flex: 1 1 0%; border: 1px solid var(--border); border-radius: 6px; padding: 6px; background: var(--surface); color: var(--text); }

.match-row button { min-width: 32px; min-height: 36px; background: var(--err); color: rgb(255, 255, 255); border-radius: 6px; }

.option-row { display: flex; gap: 6px; align-items: center; margin-bottom: 6px; }

.option-row input[type="radio"] { min-width: 20px; min-height: 20px; }

.option-row input[type="text"] { flex: 1 1 0%; border: 1px solid var(--border); border-radius: 6px; padding: 6px; background: var(--surface); color: var(--text); }

.option-row button { min-width: 32px; min-height: 36px; background: var(--err); color: rgb(255, 255, 255); border-radius: 6px; }

.empty-msg { text-align: center; padding: 30px; color: var(--text-muted); font-size: 14px; }
